Algoritmo AptoPrestamo
	Definir edad, ingresos Como Entero
	Definir historial Como Caracter
	
	Escribir "INGRESA TU EDAD"
	Leer edad
	Escribir "INGRESA TUS INGRESOS MENSUALES"
	Leer hitorial
	
	Si ( edad >= 21 Y ingresos > 1000 Y hitorial = "bueno" ) Entonces
		Escribir "APTO PARA EL PRESTAMO"
	SiNo
		Escribir "NO APTO PARA EL PRESTAMO"
	Fin Si
	
FinAlgoritmo
