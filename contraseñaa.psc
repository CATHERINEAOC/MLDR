Algoritmo ContraseÒa 
	Definir clave Como Caracter
	clave <- "secreta"
	
	Definir intento Como Caracter
	Escribir "INGREA LA CONTRASE—A:"
	Leer intento
	
	Mientras intento <> clave Hacer
		Escribir "CONTRAE—A INCORRECTA"
		Leer intento
	Fin Mientras
	
	Escribir "ACCESO CONCEDIDO"
	
FinAlgoritmo
